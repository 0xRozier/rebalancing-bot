# ============================================
# CRYPTO REBALANCING BOT - CONFIGURATION
# ============================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env (cp .env.example .env)
# 2. Fill in the REQUIRED variables below
# 3. Optional: Configure Telegram for notifications
# 4. Run: npm run dry-run (to test)
# 5. Run: npm start (to go live)
#
# SECURITY WARNING:
# - NEVER commit your .env file to GitHub
# - Keep your PRIVATE_KEY secure
# - Use a dedicated wallet for the bot
# ============================================

# ============================================
# REQUIRED - Bot will not start without these
# ============================================

# Your wallet private key (with 0x prefix or without)
# WARNING: This wallet will execute trades. Use a dedicated wallet!
# Get it from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=your_private_key_here

# RPC endpoint for Base network
# Options:
# - Infura: https://base-mainnet.infura.io/v3/YOUR_PROJECT_ID
# - Alchemy: https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# - Public: https://mainnet.base.org (not recommended for production)
# Get free RPC: https://infura.io or https://alchemy.com
RPC_URL=https://base-mainnet.infura.io/v3/YOUR_PROJECT_ID

# 1inch API key (free tier works fine)
# Get it: https://portal.1inch.dev/
# 1. Sign up
# 2. Create new API key
# 3. Copy the key here
ONEINCH_API_KEY=your_1inch_api_key_here

# ============================================
# OPTIONAL - Highly recommended for monitoring
# ============================================

# Telegram bot token (for notifications)
# Setup:
# 1. Message @BotFather on Telegram
# 2. Send /newbot
# 3. Follow instructions
# 4. Copy the token here
# Leave empty to disable notifications
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (where bot sends messages)
# Get it:
# 1. Message @userinfobot on Telegram
# 2. Copy the ID it shows
# 3. Paste here
TELEGRAM_CHAT_ID=

# ============================================
# OPTIONAL - For better price data
# ============================================

# CoinGecko API key (free tier is enough)
# Get it: https://www.coingecko.com/en/api
# Leave empty to use public API (has rate limits)
COINGECKO_API_KEY=

# ============================================
# NOTES
# ============================================
#
# MINIMUM REQUIREMENTS:
# - Wallet with BTC, ETH, stETH, and USDC on Base network
# - ~0.01 ETH for gas costs
# - Recommended portfolio: $500+ for optimal efficiency
#
# FIRST TIME SETUP:
# 1. Test with dry-run mode: npm run dry-run
# 2. Monitor for 1-2 hours
# 3. If everything looks good, go live: npm start
#
# TROUBLESHOOTING:
# - "Invalid private key": Check format (64 hex chars)
# - "RPC error": Verify your RPC URL is correct
# - "1inch error": Check API key is valid
# - "No notifications": Verify Telegram token & chat ID
#
# SUPPORT:
# - Email: [your-email]
# - Telegram: @[your-handle]
#
# ============================================
